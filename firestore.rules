rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Tests collection
    match /tests/{testId} {
      allow read: if resource.data.status == 'published' || 
                  (request.auth != null && resource.data.creatorId == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.creatorId == request.auth.uid;
      allow update: if request.auth != null && resource.data.creatorId == request.auth.uid && request.resource.data.creatorId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.creatorId == request.auth.uid;
    }
    
    // Attempts collection
    match /attempts/{attemptId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}
